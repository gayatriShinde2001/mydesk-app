{
  "name": "mydesk-app",
  "version": "1.0.0",
  "main": "./src/main/index.cjs",
  "type": "module",
  "author": {
    "email": "gayatri@infocusp.com",
    "name": "Gayatri Shinde"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron-dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --ozone-platform=x11 --disable-gpu --no-sandbox\"",
    "electron-build": "npm run build && electron-builder --linux",
    "electron-start": "./release/linux-unpacked/mydesk-app --ozone-platform=x11 --disable-gpu --no-sandbox"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "node-cron": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.mydesk.app",
    "productName": "MyDesk",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/**/*",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "icon.png",
        "to": "icon.png"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "icon"
    },
    "electronDist": "node_modules/electron/dist/.",
    "electronVersion": "latest"
  }
}